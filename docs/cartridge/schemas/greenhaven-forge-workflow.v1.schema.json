{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://greenhaven.local/schemas/greenhaven-forge-workflow.v1.schema.json",
  "title": "Greenhaven Forge Workflow v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "workflow_slug", "nodes", "edges"],
  "properties": {
    "schema_version": {
      "const": "greenhaven.forge_workflow.v1"
    },
    "workflow_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "maxLength": 120
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_-]+$"
          },
          "type": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
          },
          "version": {
            "type": "string",
            "default": "1"
          },
          "inputs": {
            "type": "array",
            "default": [],
            "items": {
              "type": "string",
              "pattern": "^[a-zA-Z0-9_-]+$"
            }
          },
          "config": {
            "type": "object",
            "default": {}
          },
          "layout": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "x": {"type": "number"},
              "y": {"type": "number"}
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to"],
        "properties": {
          "from": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_-]+$"
          },
          "to": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_-]+$"
          },
          "label": {
            "type": "string",
            "maxLength": 80
          }
        }
      }
    }
  }
}
