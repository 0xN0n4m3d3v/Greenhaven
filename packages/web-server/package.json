{
  "name": "@greenhaven/web-server",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "locales",
    "migrations",
    "baseline",
    "prompts",
    "package.json"
  ],
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "tsx --env-file=.env src/index.ts",
    "prebuild": "npm --prefix ../shared run build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "npm --prefix ../shared run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "perf:report": "tsx --env-file=.env src/scripts/perf-report.ts",
    "perf:hotspots": "tsx --env-file=.env src/scripts/perf-report.ts hotspots",
    "perf:failures": "tsx --env-file=.env src/scripts/perf-report.ts failures",
    "telemetry:report": "tsx --env-file=.env src/scripts/telemetry-report.ts",
    "telemetry:errors": "tsx --env-file=.env src/scripts/telemetry-report.ts errors",
    "telemetry:quality": "tsx --env-file=.env src/scripts/telemetry-report.ts quality",
    "telemetry:bundle": "tsx --env-file=.env src/scripts/telemetry-report.ts bundle",
    "telemetry:retention": "tsx --env-file=.env src/scripts/telemetry-report.ts retention",
    "telemetry:export": "tsx --env-file=.env src/scripts/telemetry-report.ts export",
    "content:readiness": "tsx --env-file=.env src/scripts/content-readiness-report.ts",
    "content:linkage": "tsx --env-file=.env src/scripts/location-linkage-audit.ts",
    "live:probe": "tsx --env-file=.env src/scripts/live-playtest-probe.ts",
    "live:marathon": "tsx --env-file=.env src/scripts/live-playtest-marathon.ts",
    "live:diagnose": "tsx --env-file=.env src/scripts/live-playtest-diagnose.ts",
    "live:cycle": "tsx --env-file=.env src/scripts/live-playtest-cycle.ts",
    "live:pipeline": "tsx --env-file=.env src/scripts/live-playtest-pipeline.ts",
    "live:owv17-bridge": "tsx src/scripts/owv17-runtime-bridge-smoke.ts",
    "live:notice-journal-privacy": "tsx src/scripts/notice-journal-memory-privacy-smoke.ts",
    "live:living-world-surfaces": "tsx src/scripts/living-world-cross-surface-smoke.ts",
    "live:engine-baseline-cartridge": "tsx src/scripts/engine-baseline-cartridge-smoke.ts",
    "live:cartridge-library": "tsx src/scripts/cartridge-library-smoke.ts",
    "live:cartridge-import-operator-path": "tsx src/scripts/cartridge-import-operator-path-smoke.ts",
    "live:hero-continuity": "tsx src/scripts/hero-continuity-smoke.ts",
    "card:export-npc": "tsx --env-file=.env src/scripts/entity-card-io.ts export-npc",
    "card:export-quest": "tsx --env-file=.env src/scripts/entity-card-io.ts export-quest",
    "card:import": "tsx --env-file=.env src/scripts/entity-card-io.ts import",
    "cartridge:robot:smoke": "tsx --env-file=.env src/scripts/robot-cartridge-smoke.ts",
    "cartridge:default:build": "tsx src/scripts/cartridge-default-build.ts",
    "cartridge:default:precompile-db": "tsx src/scripts/cartridge-default-precompile-db.ts",
    "cartridge:default:install-smoke": "tsx src/scripts/cartridge-default-install-smoke.ts",
    "cartridge:i18n:report": "tsx --env-file=.env src/scripts/validate-cartridge.ts --fixture-mode temp --i18n report",
    "cartridge:i18n:check": "tsx --env-file=.env src/scripts/validate-cartridge.ts --fixture-mode temp --i18n strict",
    "cartridge:i18n:author": "tsx --env-file=.env src/scripts/cartridge-i18n.ts",
    "cartridge:i18n:export": "tsx --env-file=.env src/scripts/cartridge-i18n.ts export --fixture-mode temp",
    "cartridge:i18n:diff": "tsx --env-file=.env src/scripts/cartridge-i18n.ts diff --fixture-mode temp",
    "cartridge:i18n:migration": "tsx --env-file=.env src/scripts/cartridge-i18n.ts migration",
    "obsidian:roundtrip-smoke": "tsx --env-file=.env src/scripts/obsidian-roundtrip-smoke.ts",
    "obsidian:roundtrip-verify": "tsx src/scripts/owv18-roundtrip-verification.ts",
    "obsidian:dev-apply": "tsx --env-file=.env src/scripts/obsidian-dev-apply.ts",
    "location:intros:generate": "tsx --env-file=.env src/scripts/generate-location-intro-bubbles.ts",
    "test:grant": "tsx --env-file=.env src/scripts/test-grant.ts",
    "test": "vitest run --maxWorkers=1 --minWorkers=1 --testTimeout=180000 --hookTimeout=180000",
    "test:turn": "vitest run src/__tests__/turn --maxWorkers=1 --minWorkers=1",
    "test:migrations": "vitest run src/__tests__/migrations --maxWorkers=1 --minWorkers=1 --testTimeout=180000 --hookTimeout=180000",
    "test:migrations:obsidian": "vitest run src/__tests__/migrations/obsidianPatch.test.ts --maxWorkers=1 --minWorkers=1 --testTimeout=30000 --hookTimeout=30000",
    "test:services": "vitest run src/__tests__/services --maxWorkers=1 --minWorkers=1"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.30",
    "@ai-sdk/openai-compatible": "^2.0.42",
    "@electric-sql/pglite": "^0.4.5",
    "@greenhaven/shared": "0.0.1",
    "@hono/node-server": "^1.13.7",
    "@node-rs/bcrypt": "^1.10.7",
    "ai": "^6.0.169",
    "hono": "^4.10.5",
    "pg": "^8.13.1",
    "png-chunks-encode": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.10",
    "playwright": "^1.60.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
