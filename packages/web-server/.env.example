# Required local auth secret. Generate a real dev value with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=replace-with-32-plus-byte-random-secret

# Provider keys. Gameplay turns need at least one of these; deterministic
# migrations, cartridge checks, and most diagnostics do not call providers.
DEEPSEEK_API_KEY=
FEATHERLESS_API_KEY=

# Network.
GEMINI_WEB_PORT=7777

# Database. Leave DATABASE_URL empty for local PGlite.
DATABASE_URL=
PGLITE_DATA_DIR=
PGPOOL_MAX=30
# Set to 0 only for self-signed development Postgres SSL.
PGSSL_REJECT_UNAUTHORIZED=1

# Auth. AUTH_DISABLED=1 is for local/dev only; never use it on shared traffic.
AUTH_DISABLED=0
# auto = secure cookies only in production web, 1 = always secure, 0 = never.
AUTH_COOKIE_SECURE=auto

# Turn engine watchdogs and mutation safety.
GREENHAVEN_TURN_WATCHDOG_MS=120000
GREENHAVEN_POST_TURN_SPECIALIST_WATCHDOG_MS=90000
GREENHAVEN_POST_TURN_SLOT_WATCHDOG_MS=120000
GREENHAVEN_MUTATION_BUDGET=5

# Gameplay logging.
GREENHAVEN_GAMEPLAY_LOG_DIR=
GREENHAVEN_GAMEPLAY_LOG_MAX_STRING=60000

# Deployment/runtime mode.
NODE_ENV=development
GREENHAVEN_DESKTOP=0
GREENHAVEN_WEB_UI_DIST=
GREENHAVEN_DATA_DIR=

# Debug/admin routes. Debug routes are disabled in production unless explicitly
# enabled; keys are sent in x-debug-key / x-admin-key headers.
GREENHAVEN_DEBUG_ROUTES=0
GREENHAVEN_DEBUG_KEY=
GREENHAVEN_DEBUG_SSE=0
ADMIN_KEY=

# Model overrides and prompt compression.
GREENHAVEN_BROKER_MODEL=
GREENHAVEN_NARRATOR_MODEL=
GREENHAVEN_LOCATION_INTRO_MODEL=deepseek-chat
GREENHAVEN_CAVEMAN_PROMPTS=0

# Devtools and reports.
GREENHAVEN_DEVTOOLS_TMP=
GREENHAVEN_CONTENT_REPORT_DIR=

# Telemetry export. Remote OTLP posts require explicit opt-in.
GREENHAVEN_TELEMETRY_OTLP_ENDPOINT=https://telemetry.example.invalid:4318
GREENHAVEN_TELEMETRY_ALLOW_REMOTE_EXPORT=0
