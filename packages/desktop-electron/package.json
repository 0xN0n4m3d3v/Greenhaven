{
  "name": "@greenhaven/desktop-electron",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "prepare:assets": "node scripts/prepare-assets.mjs",
    "build:ts-only": "tsc -p tsconfig.json",
    "build": "npm run prepare:assets && tsc -p tsconfig.json",
    "dev": "npm --prefix ../web-server run build && npm --prefix ../web-ui run build && npm run build && electron dist/main.js",
    "dist:win:prepared": "npm run build:ts-only && electron-builder --win --x64",
    "dist:win": "npm --prefix ../web-server run build && npm --prefix ../web-ui run build && npm run build && electron-builder --win --x64",
    "dist:win-dir:prepared": "npm run build:ts-only && electron-builder --win --x64 --dir",
    "dist:win-dir": "npm --prefix ../web-server run build && npm --prefix ../web-ui run build && npm run build && electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.30",
    "@ai-sdk/openai-compatible": "^2.0.42",
    "@electric-sql/pglite": "^0.4.5",
    "@hono/node-server": "^1.13.7",
    "@node-rs/bcrypt": "^1.10.7",
    "ai": "^6.0.169",
    "hono": "^4.10.5",
    "pg": "^8.13.1",
    "png-chunks-encode": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "electron": "41.5.0",
    "electron-builder": "^26.8.1"
  }
}
