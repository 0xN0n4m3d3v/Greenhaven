{
  "name": "@greenhaven/cartridge-forge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node cartridge authoring and export tool for Greenhaven.",
  "main": "dist/cli/index.js",
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "start": "tsx src/server/index.ts",
    "forge": "tsx src/cli/index.ts",
